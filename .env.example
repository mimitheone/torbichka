# Копирай като .env.
#
# ВАЖНО: db.*.supabase.co (Direct) е основно IPv6. На много мрежи → Connection refused.
# За Mac/домашен интернет ползвай Session pooler URI от таблото:
#   Connect → Session pooler → копирай (postgres.REF @ aws-0-REGION.pooler.supabase.com:5432)
#
# DATABASE_URL=postgresql://postgres.REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# Опционално: втори ред само за тестове (test_supabase_connection.py пробва и двата)
# DATABASE_URL_SESSION=...
#
# Direct (само ако имаш работещ IPv6):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
